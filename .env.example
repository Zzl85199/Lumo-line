# ===== 前端(build 時打包進瀏覽器,只能放「公開」的值)=====
# Supabase 專案 URL(Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://xxxx.supabase.co
# Supabase anon(public)key — 搭配 RLS 使用,可公開
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
# LIFF ID(LINE Developers Console > LIFF 分頁建立後取得,格式如 1234567890-AbcdEfgh)
VITE_LIFF_ID=1234567890-AbcdEfgh
# 加 LINE 好友連結(LINE Official Account Manager > 增加好友工具)
VITE_LINE_ADD_FRIEND_URL=https://lin.ee/xxxxxxx

# ===== 後端 Pages Functions(設定在 Cloudflare Pages 環境變數,絕不進前端)=====
# LINE Developers Console > Basic settings > Channel secret
LINE_CHANNEL_SECRET=your_channel_secret
# LINE Developers Console > Messaging API > Channel access token (long-lived)
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
# LINE Login channel 的 Channel ID(LIFF 掛的那個 channel > Basic settings)
# /api/inquiry 用來驗證 LIFF access token 屬於自己的 channel
LINE_LOGIN_CHANNEL_ID=1234567890
# 收「新諮詢單」通知的管理員 LINE userId(對 bot 輸入「我的ID」即可取得)
ADMIN_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 與上方相同的 Supabase URL
SUPABASE_URL=https://xxxx.supabase.co
# Supabase service_role key — 僅限後端使用,外洩等於整個資料庫外洩
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
